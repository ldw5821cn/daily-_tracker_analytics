# ETF Tracker 配置文件示例
# 复制此文件为 .env 并填入实际值

# WeChat Webhook URL - 用于每日报告推送到企业微信群
# 获取步骤：
# 1. 打开企业微信群（或个人微信群）
# 2. 点击右上角"..." -> 群设置
# 3. 选择"添加群机器人"
# 4. 创建机器人，复制 Webhook 地址
# 格式: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxxxxxxxxxx
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# 可选: 代理配置（如果需要）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
